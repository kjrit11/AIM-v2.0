# AIM v2 — Environment Variables
# Copy to .env.local for local dev. Never commit .env.local.
# In production, these are sourced from Databricks secret scopes
# (can be Azure Key Vault-backed), not from a file.

# ────────────────────────────────────────────────────────────────
# Node environment
# ────────────────────────────────────────────────────────────────
NODE_ENV=development

# ────────────────────────────────────────────────────────────────
# Anthropic (required)
# ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model string. Defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ────────────────────────────────────────────────────────────────
# Databricks SQL (Phase 3+)
# ────────────────────────────────────────────────────────────────
# Required for Phase 3 Databricks SQL access; leave empty in dev for now
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=

# ────────────────────────────────────────────────────────────────
# Auto-injected by Databricks Apps at runtime — do NOT fill these in
# locally. Listed here for reference only. The platform injects these
# on every request in prod; they are absent in local dev.
#   DATABRICKS_HOST, DATABRICKS_CLIENT_ID, DATABRICKS_CLIENT_SECRET,
#   DATABRICKS_APP_NAME, DATABRICKS_APP_PORT, DATABRICKS_APP_URL,
#   DATABRICKS_WORKSPACE_ID, NEXT_DEPLOYMENT_ID
# ────────────────────────────────────────────────────────────────

# ────────────────────────────────────────────────────────────────
# Observability (Phase 3+)
# ────────────────────────────────────────────────────────────────
SENTRY_DSN=
# Optional: Azure Log Analytics workspace ID
AZURE_LOG_ANALYTICS_WORKSPACE_ID=

# ────────────────────────────────────────────────────────────────
# Email (Phase 6+) — provider decided in Phase 6
# ────────────────────────────────────────────────────────────────
# If Resend:
RESEND_API_KEY=
# If Azure Communication Services:
# ACS_CONNECTION_STRING=
