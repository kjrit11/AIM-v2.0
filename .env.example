# AIM v2 — Environment Variables
# Copy to .env.local for local dev. Never commit .env.local.
# In production, these are sourced from Databricks secret scopes
# (can be Azure Key Vault-backed), not from a file.

# ────────────────────────────────────────────────────────────────
# Node environment
# ────────────────────────────────────────────────────────────────
NODE_ENV=development

# ────────────────────────────────────────────────────────────────
# Anthropic (required)
# ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model string. Defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ────────────────────────────────────────────────────────────────
# Catalog routing (required — Phase 3a)
# ────────────────────────────────────────────────────────────────
# REQUIRED. Values: sales (prod), sales_dev (local/dev), sales_demo (Phase 9).
# No default. Missing or empty crashes the process at env validation — this is
# intentional; silent defaulting to sales would let a dev process hit prod data.
AIM_CATALOG=sales_dev

# ────────────────────────────────────────────────────────────────
# Databricks SQL (required — Phase 3a)
# ────────────────────────────────────────────────────────────────
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=

# Personal access token. Preferred for local dev. Generate via Databricks
# workspace User Settings → Developer → Access tokens. See docs/DEV_SETUP.md.
DATABRICKS_TOKEN=

# ────────────────────────────────────────────────────────────────
# Auto-injected by Databricks Apps at runtime — do NOT fill these in
# locally. Listed here for reference only. The platform injects these
# on every request in prod; they are absent in local dev.
#   DATABRICKS_HOST, DATABRICKS_CLIENT_ID, DATABRICKS_CLIENT_SECRET,
#   DATABRICKS_APP_NAME, DATABRICKS_APP_PORT, DATABRICKS_APP_URL,
#   DATABRICKS_WORKSPACE_ID, NEXT_DEPLOYMENT_ID
# ────────────────────────────────────────────────────────────────

# ────────────────────────────────────────────────────────────────
# Observability (Phase 3+)
# ────────────────────────────────────────────────────────────────
# Optional in Phase 3a. When set, enables error tracking. Sentry project
# pending — when unset all Sentry code paths no-op and logger.ts still
# writes structured JSON to stdout.
SENTRY_DSN=
# Optional: Azure Log Analytics workspace ID
AZURE_LOG_ANALYTICS_WORKSPACE_ID=

# ────────────────────────────────────────────────────────────────
# Email (Phase 6+) — provider decided in Phase 6
# ────────────────────────────────────────────────────────────────
# If Resend:
RESEND_API_KEY=
# If Azure Communication Services:
# ACS_CONNECTION_STRING=
