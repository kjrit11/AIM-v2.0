# AIM v2 — Environment Variables
# Copy to .env.local for local dev. Never commit .env.local.
# In production, these are sourced from Azure Key Vault, not from a file.

# ────────────────────────────────────────────────────────────────
# Node environment
# ────────────────────────────────────────────────────────────────
NODE_ENV=development

# ────────────────────────────────────────────────────────────────
# Databricks (Phase 3+)
# ────────────────────────────────────────────────────────────────
# Workspace host (no https:// prefix)
DATABRICKS_HOST=
# SQL warehouse HTTP path, e.g. /sql/1.0/warehouses/xxxxxxxx
DATABRICKS_SQL_HTTP_PATH=
# Personal access token or OAuth service principal token
DATABRICKS_TOKEN=

# ────────────────────────────────────────────────────────────────
# NextAuth + Entra ID (Phase 2+)
# ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# ────────────────────────────────────────────────────────────────
# Anthropic (Phase 3+)
# ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Model string. Defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ────────────────────────────────────────────────────────────────
# Observability (Phase 3+)
# ────────────────────────────────────────────────────────────────
SENTRY_DSN=
# Optional: Azure Log Analytics workspace ID
AZURE_LOG_ANALYTICS_WORKSPACE_ID=

# ────────────────────────────────────────────────────────────────
# Email (Phase 6+) — provider decided in Phase 6
# ────────────────────────────────────────────────────────────────
# If Resend:
RESEND_API_KEY=
# If Azure Communication Services:
# ACS_CONNECTION_STRING=
